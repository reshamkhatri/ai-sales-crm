# Copy this to .env and fill in your real keys

# AI provider (Required for real AI). Use EITHER Claude OR OpenAI.
#
# Option A — Claude (Anthropic). Preferred when ANTHROPIC_API_KEY is set.
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-8
#
# Option B — OpenAI OR any OpenAI-compatible API (used only if no Claude key).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# To use DeepSeek instead of OpenAI, set:
#   OPENAI_API_KEY=sk-your-deepseek-key
#   OPENAI_BASE_URL=https://api.deepseek.com
#   OPENAI_MODEL=deepseek-chat
OPENAI_BASE_URL=

# Lead prospecting (all optional — free scraping works without keys)
GOOGLE_MAPS_API_KEY=          # Google Places API key (optional, more reliable)
SERPAPI_KEY=                  # SerpAPI key (optional, reliable Maps scraping)

# Lead Finder browser extension — the x-api-key it must send.
# Leave blank to accept any non-empty key (easy local use); set a value to lock it.
LEADFINDER_API_KEY=

# Meta / Facebook (Required for Facebook + Instagram)
META_ACCESS_TOKEN=your-page-access-token
META_AD_ACCOUNT_ID=act_1234567890
META_PAGE_ID=your-page-id
META_VERIFY_TOKEN=fb_webhook_123
META_APP_SECRET=your-app-secret
META_INSTAGRAM_ID=your-instagram-business-id

# WhatsApp Cloud API (Required for WhatsApp auto-reply)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id  # From WhatsApp Business Manager > Phone Numbers
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token  # Often SAME as META_ACCESS_TOKEN
WHATSAPP_VERIFY_TOKEN=wa_webhook_123

# Email - Gmail (Required for email monitoring)
EMAIL_ADDRESS=youragency@gmail.com
EMAIL_PASSWORD=your-app-password  # Generate at myaccount.google.com/apppasswords
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Telegram (Optional)
TELEGRAM_BOT_TOKEN=your-bot-token  # Get from @BotFather

# Active Channels (comma-separated)
ACTIVE_CHANNELS=facebook,whatsapp,instagram,email,telegram

# Database
DATABASE_PATH=database/sales_assistant.db

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Agency Info
AGENCY_NAME=Your Dubai Web Design Agency
AGENCY_SERVICES=Web Design, Landing Pages, SEO, E-commerce
AGENCY_LOCATION=Dubai, UAE
